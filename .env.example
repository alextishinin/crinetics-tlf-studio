# Anthropic API key — required for all AI features (SAP extraction,
# anomaly detection, NL shell selection, table chat).
ANTHROPIC_API_KEY=

# Filesystem root where each study lives (one subdirectory per study UUID).
STUDIES_ROOT=./studies

# Local path to the crinetics-tlf-automation project. The backend imports
# from <TLF_AUTOMATION_PATH>/src/tlf/.
TLF_AUTOMATION_PATH=../crinetics-tlf-automation

# Path to the TLF shell registry (within the automation project) and the
# default study config template used as a starting point for new studies.
TLF_REGISTRY_PATH=../crinetics-tlf-automation/shells/registry.yaml
TLF_DEFAULT_CONFIG_PATH=../crinetics-tlf-automation/config/study_config.yaml

# Celery / Redis (only needed when TLF_JOB_EXECUTOR=celery)
REDIS_URL=redis://localhost:6379/0

# How generation jobs run: background (default; worker thread + UI polling),
# inline (synchronous), or celery (Redis-backed worker).
TLF_JOB_EXECUTOR=background

# Browser origins allowed to call the API (comma-separated). Keep this
# restricted — the API is unauthenticated and holds study data.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Internal + public-facing API base URLs
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Anthropic model
ANTHROPIC_MODEL=claude-sonnet-4-6
